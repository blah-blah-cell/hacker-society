FROM ubuntu:22.04

RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    curl \
    bash \
    net-tools \
    iproute2 \
    && rm -rf /var/lib/apt/lists/*

# Set up a vulnerable-ish web server
WORKDIR /app
COPY --chown=root:root server.py /app/server.py

# A secret token will be injected here during match initialization
# CMD runs the python server and keeps the container alive
CMD ["python3", "/app/server.py"]
